# Compose / Postgres
POSTGRES_DB=nvltrnslt
POSTGRES_USER=nvltrnslt
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

# App
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
DATABASE_URL=postgres://nvltrnslt:replace-with-a-strong-postgres-password@db:5432/nvltrnslt
BILLING_MODE=disabled

# First bootstrap admin for `node scripts/db-seed.mjs`
BOOTSTRAP_ADMIN_NAME=Production Admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-bootstrap-password-at-least-12-chars

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=

# Optional Yandex translation provider
YANDEX_TRANSLATE_FOLDER_ID=
YANDEX_TRANSLATE_API_KEY=

# Translation runtime
TRANSLATION_TIMEOUT_MS=8000
TRANSLATION_MAX_RETRIES=2
TRANSLATION_RETRY_DELAY_MS=400
TRANSLATION_DEGRADED_MODE=fallback

# Optional runtime knobs for `node scripts/db-migrate.mjs`
DB_STARTUP_TIMEOUT_SECONDS=60
DB_STARTUP_RETRY_DELAY_MS=2000
